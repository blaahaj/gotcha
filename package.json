{
  "name": "@blaahaj/gotcha",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "format": "prettier --write --list-different .",
    "test": "concurrently --group=true pnpm:test:\\*",
    "test:format": "prettier --check .",
    "test:lint": "eslint src test",
    "test:package-json": "npmPkgJsonLint .",
    "test:unit": "node --test --enable-source-maps './dist/test/*.test.js'"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.6.0",
      "onFail": "download"
    }
  },
  "type": "module",
  "exports": {
    ".": "./dist/src/index.js",
    "./Either": "./dist/src/either.js",
    "./Error": "./dist/src/error.js",
    "./Object": "./dist/src/object.js",
    "./Option": "./dist/src/option.js",
    "./Throw": "./dist/src/throw.js"
  },
  "files": [
    "dist/src",
    "*.md"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.3",
    "concurrently": "^10.0.3",
    "eslint": "^10.5.0",
    "npm-package-json-lint": "^10.4.0",
    "npm-package-json-lint-config-default": "^9.0.1",
    "prettier": "^3.8.4",
    "prettier-cli": "^0.1.0",
    "prettier-plugin-packagejson": "^3.0.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  }
}
